# CIMIC Databricks Workshop  -  Environment Configuration
# -------------------------------------------------------
# Copy this file per environment and fill in the values.
# These map directly to DABS target variables in databricks.yml.
#
# Usage:
#   1. Copy this file:  cp env.example env.dev   (or env.prod, env.staging)
#   2. Fill in all REPLACE_* values
#   3. Deploy:  databricks bundle deploy -t dev
#              (target name must match a target block in databricks.yml)

# -- Workspace --
# The Databricks workspace URL for this environment
DATABRICKS_HOST=https://adb-XXXXXXXXX.azuredatabricks.net

# -- Compute --
# An existing all-purpose cluster ID (avoids spinning up new clusters per task)
# Find it: Compute > your cluster > Advanced > Cluster ID
CLUSTER_ID=REPLACE_WITH_CLUSTER_ID

# -- Unity Catalog --
# The catalog name to create schemas and tables in
# Each environment should have its own catalog for isolation
CATALOG_NAME=REPLACE_WITH_CATALOG

# -- SQL Warehouse --
# Name of the SQL Warehouse for Genie Spaces and materialized views
# Must be Serverless or Pro (not Classic) for MV support
WAREHOUSE_NAME=Serverless Starter Warehouse

# -- External Storage (ADLS) --
# The ADLS Gen2 path for external Delta tables
# Format: abfss://<container>@<account>.dfs.core.windows.net/<path>
# Each environment should use a separate path or container
EXTERNAL_STORAGE_PATH=abfss://datalake@REPLACE_ACCOUNT.dfs.core.windows.net/REPLACE_PATH

# -- Customer --
# Display name used in Genie Space titles, RLS group names, etc.
CUSTOMER_NAME=REPLACE_WITH_CUSTOMER_NAME

# -- Data Volume --
# Row counts for generated data (optional, defaults shown)
# NUM_TELEMETRY_ROWS=5000
# NUM_INCIDENT_ROWS=1500
# NUM_PROCUREMENT_ROWS=1200
# NUM_PROJECT_ROWS=120
# NUM_PROJECTS=120
# NUM_MATERIAL_ROWS=1200

# -------------------------------------------------------
# Fabric Integration (optional)
# -------------------------------------------------------
# Set these if using Microsoft Fabric mirroring / lakehouse integration.

# FABRIC_WORKSPACE=REPLACE_WITH_FABRIC_WORKSPACE_NAME
# FABRIC_CAPACITY=REPLACE_WITH_FABRIC_CAPACITY_NAME
# DBX_HOST=REPLACE_WITH_DATABRICKS_HOST_FOR_FABRIC
# DBX_CATALOG=REPLACE_WITH_DATABRICKS_CATALOG_FOR_FABRIC

# -------------------------------------------------------
# To add a new target in databricks.yml, copy the dev block:
#
#   my_new_env:
#     mode: development   # or 'production' for prod
#     variables:
#       databricks_host: "https://adb-XXXXXXXXX.azuredatabricks.net"
#       cluster_id: "REPLACE_WITH_CLUSTER_ID"
#       catalog_name: cimic_new_env
#       external_storage_path: "abfss://..."
#
# Then deploy:
#   databricks bundle deploy -t my_new_env
#   databricks bundle run manufacturing_setup -t my_new_env
#   databricks bundle run supply_chain_pipeline -t my_new_env
# -------------------------------------------------------
