# Azure AI Foundry project endpoint
# Example: https://<account>.services.ai.azure.com/api/projects/<project>
AZURE_AI_PROJECT_ENDPOINT=

# Judge model deployment name (must exist in your project)
JUDGE_MODEL_DEPLOYMENT=gpt-4o

# Agent to evaluate
AGENT_NAME=cimic-project-advisor
# AGENT_VERSION=1  # Optional — leave blank to use latest

# Evaluation dataset settings
EVAL_DATASET_NAME=cimic-agent-eval-v1
EVAL_DATASET_VERSION=1
EVAL_NAME=cimic-agent-eval-v1
