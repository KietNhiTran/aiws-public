# =============================================================================
# Contoso AI Workshop — Master Environment Configuration
# =============================================================================
# This file consolidates all environment variables needed to deploy and run
# Module 03 (Databricks + Fabric integration).
#
# Usage:
#   1. Copy this file:  cp .env.example .env.local
#   2. Fill in ALL values marked REPLACE_WITH_*
#   3. Source it:        source .env.local  (Linux/Mac)
#                        or load with python-dotenv / direnv
# =============================================================================

# -----------------------------------------------------------------------------
# Azure Identity
# -----------------------------------------------------------------------------
AZURE_TENANT_ID=REPLACE_WITH_TENANT_ID
AZURE_SUBSCRIPTION_ID=REPLACE_WITH_SUBSCRIPTION_ID
AZURE_RESOURCE_GROUP=REPLACE_WITH_RESOURCE_GROUP

# Service Principal (optional — for CI/CD automation)
# SP_CLIENT_ID=REPLACE_WITH_SP_CLIENT_ID
# SP_CLIENT_SECRET=REPLACE_WITH_SP_CLIENT_SECRET

# -----------------------------------------------------------------------------
# Environment
# -----------------------------------------------------------------------------
# Which environment to target: dev, staging, or prod
ENVIRONMENT=dev

# Customer display name — used in Genie Space titles, table comments, etc.
CUSTOMER_NAME=Contoso

# -----------------------------------------------------------------------------
# Databricks
# -----------------------------------------------------------------------------
# Workspace URL (e.g., https://adb-XXXXXXXXX.X.azuredatabricks.net)
DATABRICKS_HOST=REPLACE_WITH_DATABRICKS_HOST

# Existing all-purpose cluster ID (Compute > your cluster > Advanced > Cluster ID)
DATABRICKS_CLUSTER_ID=REPLACE_WITH_CLUSTER_ID

# Unity Catalog — catalog name for this environment
DATABRICKS_CATALOG=contoso_dev

# SQL Warehouse name (must be Serverless or Pro for materialized view support)
DATABRICKS_WAREHOUSE=Serverless Starter Warehouse

# External storage path (ADLS Gen2) — optional, for external Delta tables
# Format: abfss://<container>@<account>.dfs.core.windows.net/<path>
DATABRICKS_EXTERNAL_STORAGE=abfss://datalake@REPLACE_ACCOUNT.dfs.core.windows.net/contoso-dev

# -----------------------------------------------------------------------------
# Fabric
# -----------------------------------------------------------------------------
# Fabric workspace name
FABRIC_WORKSPACE=contoso-aiws-dev

# Fabric capacity name (must be provisioned in your Azure subscription)
FABRIC_CAPACITY=REPLACE_WITH_CAPACITY_NAME

# Databricks connection details for Fabric mirroring
FABRIC_DBX_HOST=REPLACE_WITH_DATABRICKS_HOST
FABRIC_DBX_CATALOG=contoso_dev

# -----------------------------------------------------------------------------
# Data Generation (optional — defaults shown)
# -----------------------------------------------------------------------------
# NUM_PROJECTS=120
# NUM_TELEMETRY_ROWS=5000
# NUM_INCIDENT_ROWS=1500
# NUM_MATERIAL_ROWS=1200
# NUM_PROCUREMENT_ROWS=1200

# =============================================================================
# Quick Reference — Deployment Commands
# =============================================================================
# Databricks (via Asset Bundles):
#   cd src/databricks
#   databricks bundle deploy -t dev
#   databricks bundle run module03_data_setup -t dev
#   databricks bundle run module03_genie_spaces -t dev
#
# Fabric:
#   cd src/fabric
#   python scripts/01_deploy_workspace.py --workspace $FABRIC_WORKSPACE \
#     --capacity $FABRIC_CAPACITY \
#     --dbx-host $FABRIC_DBX_HOST --dbx-catalog $FABRIC_DBX_CATALOG
#   python scripts/02_populate_sql_db.py --config scripts/config.json
#   python scripts/03_populate_lakehouse.py --config scripts/config.json
# =============================================================================
